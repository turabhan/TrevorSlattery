<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="20260428-product-table-v2" author="trevor">
        <createTable tableName="product_entity">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(19, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="image_url" type="VARCHAR(500)"/>
            <column name="category" type="VARCHAR(255)"/>
            <column name="description" type="VARCHAR(1000)"/>
            <column name="quantity" type="INT"/>
        </createTable>
    </changeSet>

    <changeSet id="20260428-cart-item-table-v2" author="trevor">
        <createTable tableName="cart_item_entity">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="product_id"
                                 baseTableName="cart_item_entity"
                                 constraintName="fk_cart_product"
                                 referencedColumnNames="id"
                                 referencedTableName="product_entity"/>
    </changeSet>

    <changeSet id="20260428-order-table-v2" author="trevor">
        <createTable tableName="orders">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="total_price" type="DECIMAL(19, 2)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(50)"/>
            <column name="created_at" type="TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="20260428-order-item-table-v2" author="trevor">
        <createTable tableName="order_items">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="order_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="product_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="quantity" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="price" type="DECIMAL(19, 2)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addForeignKeyConstraint baseColumnNames="order_id"
                                 baseTableName="order_items"
                                 constraintName="fk_order_item_order"
                                 referencedColumnNames="id"
                                 referencedTableName="orders"/>
    </changeSet>

    <changeSet id="20260428-data-seed-v2" author="trevor">
        <insert tableName="product_entity">
            <column name="name" value="Сочное Яблоко"/>
            <column name="price" value="150.00"/>
        </insert>
        <insert tableName="product_entity">
            <column name="name" value="Спелый Банан"/>
            <column name="price" value="90.00"/>
        </insert>
    </changeSet>

    <changeSet id="20260428-create-transaction-log" author="trevor">
        <createTable tableName="transaction_log_entity">
            <column name="id" type="BIGINT" incrementBy="1">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="message" type="VARCHAR(255)"/>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="action" type="VARCHAR(255)"/>
            <column name="details" type="VARCHAR(1000)"/>
            <column name="timestamp" type="TIMESTAMP"/>
            <column name="user_id" type="BIGINT"/>
        </createTable>
    </changeSet>

</databaseChangeLog>